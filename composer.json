{
    "name": "cstudios-slovakia/ccrm",
    "description": "This package is the base for the Cstudios CRM system",
    "type": "composer-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Cstudios Slovakia",
            "email": "cstudios@softwaresolutions.sk"
        }
    ],
    "require": {
        "php": ">=8.0",
        "composer-plugin-api": "^1.1 || ^2.0"
    },
    "autoload": {
        "psr-4": {
            "CCRM\\": "src-php/"
        }
    },
    "extra": {
        "class": "CCRM\\ComposerPlugin"
    },
    "scripts": {
        "post-install-cmd": [
            "CCRM\\Installer::publishAssets"
        ],
        "post-update-cmd": [
            "CCRM\\Installer::publishAssets"
        ]
    }
}