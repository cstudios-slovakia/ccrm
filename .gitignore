# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# node_modules
node_modules

# Build output. The built frontend (dist/index.html + dist/assets/) IS tracked so the
# server can deploy it via `git pull` + `php ccrm update` (the publish step copies
# dist/* to the docroot; there is no Node/build step on the server).
# The root index.html stays the Vite source entry (points at /src/main.tsx); the built
# index.html lives in dist/ and overwrites the root copy at publish time.
# Everything else under dist/ (PHP copied from public/) and the published root /assets/
# are regenerated locally and stay out of git.
/dist/*
!/dist/index.html
!/dist/assets/
/assets/
dist-ssr
*.local

# Local scratch / personal to-do notes (not part of the app)
chyby na opravu.txt

# Secrets / runtime-generated files — never commit real credentials.
config.php
**/config.php
api_key.txt
**/api_key.txt
uploads/
**/uploads/
server.md

# Throwaway maintenance scripts and raw client data — never commit; these were
# publicly served from the docroot and leaked PII (see security audit).
scratch/
tempData/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

/.claude/
