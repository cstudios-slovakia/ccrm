#!/usr/bin/env php
<?php
/**
 * CCRM CLI Update & Management Tool
 */

if (php_sapi_name() !== 'cli') {
    die("This script can only be run from the command line.\n");
}

$args = $argv;
$command = isset($args[1]) ? $args[1] : 'help';

switch ($command) {
    case 'update':
        ccrm_update();
        break;
    case 'migrate':
        ccrm_migrate();
        break;
    case 'help':
    default:
        ccrm_help();
        break;
}

function ccrm_help() {
    echo "CCRM CLI Tool\n";
    echo "Usage:\n";
    echo "  php ccrm update   - Pulls latest code, runs composer install, publishes assets, and migrates DB\n";
    echo "  php ccrm migrate  - Runs database migrations manually\n";
    echo "  php ccrm help     - Shows this help message\n";
}

function ccrm_update() {
    echo "Starting CCRM Update Process...\n";

    // 1. Check for local modifications blocking git pull
    echo "Checking git status...\n";
    exec("git diff --name-only", $dirtyFiles);
    exec("git diff --cached --name-only", $stagedFiles);
    $dirty = array_unique(array_filter(array_merge($dirtyFiles, $stagedFiles)));

    // index.html is expected to differ locally after a build (the dist/ copy
    // overwrites it with build-specific markup) — safe to discard every run.
    //
    // vendor/composer/installed.php is expected to differ after step 3 below:
    // `composer install` always stamps it with the current git commit hash,
    // so it goes dirty on every run and would otherwise block the *next*
    // `php ccrm update` for no real reason — safe to discard every run.
    $autoRestore = ['index.html', 'vendor/composer/installed.php'];
    $toRestore = array_intersect($autoRestore, $dirty);
    if (!empty($toRestore)) {
        foreach ($toRestore as $file) {
            echo "Restoring $file to avoid conflict...\n";
            passthru("git checkout -- " . escapeshellarg($file));
        }
    }

    // Any OTHER dirty tracked file must NOT be auto-stashed: a stash created
    // here would get popped back after the pull below, re-applying whatever
    // stale local edit was sitting in the file ON TOP of the freshly-pulled
    // code — silently reverting the very fix the update was meant to deliver.
    // This is exactly what happened on 2026-07-10: a forgotten local edit to
    // sync.php kept resurrecting itself after every `php ccrm update`, masking
    // real fixes (including a data-loss guard) for days. Fail loudly instead
    // and make the operator resolve it explicitly.
    $unexpectedDirty = array_values(array_diff($dirty, $autoRestore));
    if (!empty($unexpectedDirty)) {
        echo "Error: unexpected local modifications to tracked file(s), refusing to auto-stash:\n";
        foreach ($unexpectedDirty as $file) {
            echo "  - $file\n";
        }
        echo "Inspect with `git diff`, then commit, `git stash`, or `git checkout --` each file\n";
        echo "manually before re-running `php ccrm update`.\n";
        exit(1);
    }

    // 2. Pull latest code
    echo "Pulling latest code from origin/main...\n";
    passthru("git pull origin main", $pullResult);
    if ($pullResult !== 0) {
        echo "Error: git pull failed.\n";
        exit(1);
    }

    // 3. Run composer install
    echo "Running composer install to update dependencies...\n";
    passthru("composer install", $composerResult);
    if ($composerResult !== 0) {
        echo "Error: composer install failed.\n";
        exit(1);
    }

    // 3b. Audit dependencies for known vulnerabilities (non-fatal, informational).
    echo "Auditing PHP dependencies (composer audit)...\n";
    passthru("composer audit --no-interaction 2>&1", $auditResult);
    if ($auditResult !== 0) {
        echo "Warning: composer audit reported advisories above. Review before/after deploy.\n";
    }

    // 4. Publish assets (copy dist/* to root) if we are in a direct git clone deployment
    $isVendor = file_exists(__DIR__ . '/../../composer.json') && strpos(__DIR__, 'vendor/cstudios-slovakia') !== false;
    if (!$isVendor) {
        echo "Publishing built assets from dist/ to root directory...\n";
        require_once __DIR__ . '/src-php/Installer.php';
        // Refresh dist/ backend PHP from public/ (the tracked source of truth)
        // BEFORE publishing. Locally `vite build` copies public/* into dist/*,
        // but there is no build step on the server, so dist/*.php (e.g.
        // dist/sync.php, which is gitignored and never pulled) would otherwise
        // stay stale and overwrite the freshly-pulled root sync.php on publish.
        // This reproduces the build's public/->dist/ copy so backend fixes
        // actually reach the served root files. (dist/index.html + dist/assets/
        // are the built frontend; public/ has no index.html/assets, so they are
        // left untouched.)
        if (is_dir(__DIR__ . '/public')) {
            \CCRM\Installer::copyDir(__DIR__ . '/public', __DIR__ . '/dist', ['config.php']);
        }
        \CCRM\Installer::copyDir(__DIR__ . '/dist', __DIR__, ['config.php']);
    }

    // 5. Run database migrations
    ccrm_migrate();

    // 6. Optional post-deploy health check. Set CCRM_HEALTHCHECK_URL (or pass a
    //    URL as the 2nd CLI arg) to verify the live site responds after deploy.
    global $args;
    $healthUrl = getenv('CCRM_HEALTHCHECK_URL');
    if (empty($healthUrl) && !empty($args[2])) {
        $healthUrl = $args[2];
    }
    if (!empty($healthUrl) && function_exists('curl_init')) {
        echo "Running post-deploy health check: $healthUrl\n";
        $ch = curl_init($healthUrl);
        curl_setopt_array($ch, [
            CURLOPT_RETURNTRANSFER => true,
            CURLOPT_TIMEOUT        => 15,
            CURLOPT_FOLLOWLOCATION => true,
        ]);
        curl_exec($ch);
        $code = (int)curl_getinfo($ch, CURLINFO_HTTP_CODE);
        curl_close($ch);
        if ($code >= 200 && $code < 400) {
            echo "Health check OK (HTTP $code).\n";
        } else {
            echo "WARNING: health check returned HTTP $code — verify the deployment.\n";
        }
    } else {
        echo "Tip: set CCRM_HEALTHCHECK_URL to enable an automatic post-deploy health check.\n";
    }

    echo "\nSuccess! CCRM updated successfully to the latest version.\n";
}

function ccrm_migrate() {
    echo "Running database migrations...\n";
    
    // Require autoloader
    $autoloader = __DIR__ . '/vendor/autoload.php';
    if (!file_exists($autoloader)) {
        echo "Error: vendor/autoload.php not found. Please run composer install first.\n";
        exit(1);
    }
    require_once $autoloader;

    // Load config
    $configFile = __DIR__ . '/config.php';
    if (!file_exists($configFile)) {
        $configFile = __DIR__ . '/public/config.php';
    }
    
    if (!file_exists($configFile)) {
        echo "Warning: config.php not found. Skipping database migrations (setup wizard will handle this on first run).\n";
        return;
    }

    // Force connection variables to be loaded into global scope
    global $pdo, $db_connection_error;
    require_once $configFile;
    
    if (!function_exists('get_db_connection')) {
        echo "Error: get_db_connection() function not found in config.php.\n";
        exit(1);
    }

    $schemaFile = __DIR__ . '/dist/api/schema.php';
    if (!file_exists($schemaFile)) {
        $schemaFile = __DIR__ . '/public/api/schema.php';
    }
    require_once $schemaFile;

    try {
        $pdo = get_db_connection();
        ccrm_apply_schema($pdo);
        echo "Database schema migrated successfully.\n";
    } catch (\Exception $e) {
        echo "Error running database migration: " . $e->getMessage() . "\n";
        exit(1);
    }
}
