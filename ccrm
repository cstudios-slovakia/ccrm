#!/usr/bin/env php
<?php
/**
 * CCRM CLI Update & Management Tool
 */

if (php_sapi_name() !== 'cli') {
    die("This script can only be run from the command line.\n");
}

$args = $argv;
$command = isset($args[1]) ? $args[1] : 'help';

switch ($command) {
    case 'update':
        ccrm_update();
        break;
    case 'migrate':
        ccrm_migrate();
        break;
    case 'help':
    default:
        ccrm_help();
        break;
}

function ccrm_help() {
    echo "CCRM CLI Tool\n";
    echo "Usage:\n";
    echo "  php ccrm update   - Pulls latest code, runs composer install, publishes assets, and migrates DB\n";
    echo "  php ccrm migrate  - Runs database migrations manually\n";
    echo "  php ccrm help     - Shows this help message\n";
}

function ccrm_update() {
    echo "Starting CCRM Update Process...\n";

    // 1. Check for local modifications blocking git pull
    echo "Checking git status...\n";
    exec("git diff --name-only", $dirtyFiles);
    exec("git diff --cached --name-only", $stagedFiles);
    $dirty = array_unique(array_merge($dirtyFiles, $stagedFiles));
    
    $hasChanges = false;
    foreach ($dirty as $file) {
        if ($file === 'index.html') {
            echo "Restoring index.html to avoid conflict...\n";
            passthru("git checkout -- index.html");
        } else if (!empty($file)) {
            $hasChanges = true;
        }
    }

    if ($hasChanges) {
        echo "Warning: You have uncommitted changes. Stashing them...\n";
        passthru("git stash");
    }

    // 2. Pull latest code
    echo "Pulling latest code from origin/main...\n";
    passthru("git pull origin main", $pullResult);
    if ($pullResult !== 0) {
        echo "Error: git pull failed.\n";
        if ($hasChanges) {
            passthru("git stash pop");
        }
        exit(1);
    }

    // 3. Run composer install
    echo "Running composer install to update dependencies...\n";
    passthru("composer install", $composerResult);
    if ($composerResult !== 0) {
        echo "Error: composer install failed.\n";
        exit(1);
    }

    if ($hasChanges) {
        echo "Restoring stashed changes...\n";
        passthru("git stash pop");
    }

    // 4. Publish assets (copy dist/* to root) if we are in a direct git clone deployment
    $isVendor = file_exists(__DIR__ . '/../../composer.json') && strpos(__DIR__, 'vendor/cstudios-slovakia') !== false;
    if (!$isVendor) {
        echo "Publishing built assets from dist/ to root directory...\n";
        require_once __DIR__ . '/src-php/Installer.php';
        \CCRM\Installer::copyDir(__DIR__ . '/dist', __DIR__, ['config.php']);
    }

    // 5. Run database migrations
    ccrm_migrate();

    echo "\nSuccess! CCRM updated successfully to the latest version.\n";
}

function ccrm_migrate() {
    echo "Running database migrations...\n";
    
    // Require autoloader
    $autoloader = __DIR__ . '/vendor/autoload.php';
    if (!file_exists($autoloader)) {
        echo "Error: vendor/autoload.php not found. Please run composer install first.\n";
        exit(1);
    }
    require_once $autoloader;

    // Load config
    $configFile = __DIR__ . '/config.php';
    if (!file_exists($configFile)) {
        $configFile = __DIR__ . '/public/config.php';
    }
    
    if (!file_exists($configFile)) {
        echo "Warning: config.php not found. Skipping database migrations (setup wizard will handle this on first run).\n";
        return;
    }

    require_once $configFile;
    if (!function_exists('get_db_connection')) {
        echo "Error: get_db_connection() function not found in config.php.\n";
        exit(1);
    }

    $schemaFile = __DIR__ . '/dist/api/schema.php';
    if (!file_exists($schemaFile)) {
        $schemaFile = __DIR__ . '/public/api/schema.php';
    }
    require_once $schemaFile;

    try {
        $pdo = get_db_connection();
        ccrm_apply_schema($pdo);
        echo "Database schema migrated successfully.\n";
    } catch (\Exception $e) {
        echo "Error running database migration: " . $e->getMessage() . "\n";
        exit(1);
    }
}
