# CCRM web root configuration.

# Serve the CRM single-page app (index.html) as the directory index.
# On shared hosts (e.g. Websupport) the default DirectoryIndex prefers
# index.php, which served the host's parking page instead of the app.
DirectoryIndex index.html index.php

# Never expose secrets or documentation via direct web requests.
# (These files are still readable by PHP's include/require server-side.)
<IfModule mod_authz_core.c>
    <FilesMatch "(^config\.php$|^api_key\.txt$|\.(md|sample\.php)$)">
        Require all denied
    </FilesMatch>
</IfModule>
<IfModule !mod_authz_core.c>
    <FilesMatch "(^config\.php$|^api_key\.txt$|\.(md|sample\.php)$)">
        Order allow,deny
        Deny from all
    </FilesMatch>
</IfModule>

# Disable directory listing.
Options -Indexes

# Raise upload limits for file attachments when PHP runs as an Apache module.
# (PHP-FPM / CGI / LiteSpeed read these from .user.ini instead.)
# Guarded so non-mod_php servers do not 500 on these directives.
<IfModule mod_php.c>
    php_value upload_max_filesize 64M
    php_value post_max_size 80M
</IfModule>
<IfModule mod_php7.c>
    php_value upload_max_filesize 64M
    php_value post_max_size 80M
</IfModule>
<IfModule mod_php8.c>
    php_value upload_max_filesize 64M
    php_value post_max_size 80M
</IfModule>
